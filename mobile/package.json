    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "detox": "^20.15.0",
    "detox-cli": "^20.15.0",
    "jest": "^29.7.0",
    "typescript": "^5.2.0"
  },
  "private": true
