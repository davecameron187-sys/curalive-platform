# Production Environment Configuration
# Copy this file to .env.production and fill in actual values

# ============================================
# Database
# ============================================
DATABASE_URL=mysql://user:password@host:3306/curalive_prod

# ============================================
# OAuth & Authentication
# ============================================
VITE_APP_ID=your_production_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://login.manus.im
JWT_SECRET=your_production_jwt_secret

# ============================================
# Manus Built-in APIs
# ============================================
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_production_forge_key
VITE_FRONTEND_FORGE_API_KEY=your_production_frontend_key

# ============================================
# Third-party Integrations
# ============================================
RECALL_AI_API_KEY=your_recall_ai_key
RECALL_AI_BASE_URL=https://api.recall.ai
RECALL_AI_WEBHOOK_SECRET=your_recall_webhook_secret

TELNYX_API_KEY=your_telnyx_key
TELNYX_SIP_CONNECTION_ID=your_sip_connection_id
TELNYX_SIP_USERNAME=your_sip_username
TELNYX_SIP_PASSWORD=your_sip_password

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY=your_twilio_api_key
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_CALLER_ID=+1234567890
TWILIO_TWIML_APP_SID=your_twiml_app_sid

ABLY_API_KEY=your_ably_key

RESEND_API_KEY=your_resend_key

MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# ============================================
# Custom Billing Platform
# ============================================
BILLING_API_URL=https://api.yourbillingplatform.com
BILLING_API_KEY=your_billing_api_key

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=your_sentry_dsn
VITE_ANALYTICS_ENDPOINT=https://analytics.yourdomain.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# ============================================
# Owner Information
# ============================================
OWNER_NAME=Your Name
OWNER_OPEN_ID=your_open_id

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
VITE_APP_TITLE=CuraLive
VITE_APP_LOGO=https://cdn.yourdomain.com/logo.png
VITE_APP_ID=your_app_id

# ============================================
# Server Configuration
# ============================================
PORT=3000
HOST=0.0.0.0

# ============================================
# Security
# ============================================
CORS_ORIGIN=https://chorusai-mdu4k2ib.manus.space,https://curalive-mdu4k2ib.manus.space
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================
# Caching
# ============================================
CACHE_TTL_SPEAKERS=600000
CACHE_TTL_ANALYTICS=300000
CACHE_TTL_SESSIONS=60000
CACHE_MAX_SIZE=1000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
