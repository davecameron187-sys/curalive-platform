# CuraLive Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env with real secrets

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/curalive

# ─── OpenAI (required for AI modules) ───
OPENAI_API_KEY=sk-your-key-here

# ─── Recall.ai (required for Shadow Mode meeting bots) ───
RECALL_AI_API_KEY=your-recall-ai-key

# ─── Mux (video/recording webhooks) ───
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# ─── Email (Resend) ───
RESEND_API_KEY=your-resend-key

# ─── Application URL (used for webhooks and callbacks) ───
# Set to your deployment URL or Codespace forwarded URL
APP_URL=https://your-app-url.com

# ─── Optional ───
# NODE_ENV=production
# JWT_SECRET=your-jwt-secret
# OAUTH_SERVER_URL=your-oauth-url
