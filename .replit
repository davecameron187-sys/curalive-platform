modules = ["nodejs-24", "python-3.12", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CuraLive AI Core"

[[workflows.workflow]]
name = "CuraLive AI Core"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd curalive_ai_core && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql"]

[userenv]

[userenv.shared]
RECALL_AI_WEBHOOK_SECRET = "df20db331b74bdef5211ee184a391566ecd2c9636ca9a63a8a3105c68efa609c"
APP_URL = "https://curalive-platform.replit.app"
